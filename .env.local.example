NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# M-Pesa / Internal bridge security
# HMAC secret shared between the M-Pesa callback and /api/wallet/bridge-mpesa.
# MUST be set in production. 32+ random bytes (e.g. `openssl rand -hex 32`).
INTERNAL_BRIDGE_SECRET=

# Optional: cap how much USDC /api/wallet/bridge-mpesa can move per call.
# Defence-in-depth on top of the HMAC gate. Default 10000.
MAX_BRIDGE_AMOUNT_USDC=10000

# Optional: set to "1" only in sandbox/staging to skip the Safaricom IP
# allow-list for /api/mpesa/callback*. Never set in production.
MPESA_SKIP_IP_CHECK=

# Wallet encryption (used ONLY by the recover-usdc.js ops script).
# Must be 32+ chars. There is no fallback -- the script refuses to run without it.
WALLET_ENCRYPTION_KEY=

# Operator private key (for backend transaction submission)
OPERATOR_PRIVATE_KEY=

# Other existing env vars...

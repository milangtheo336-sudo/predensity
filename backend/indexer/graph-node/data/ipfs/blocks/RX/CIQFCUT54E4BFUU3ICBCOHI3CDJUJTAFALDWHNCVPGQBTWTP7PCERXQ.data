    mapping:
      abis:
        - file:
            /: /ipfs/QmcMBiJcMSLPLsttwZVnCNAe43KxF6LEUbED4UeY6GmYiP
          name: CryptoPredictionMarket
      apiVersion: 0.0.6
      entities:
        - User
        - UserStats
        - Market
        - Bet
        - Fee
        - Bucket
        - PriceAtTimestamp
      eventHandlers:
        - event: >-
            BetPlaced(indexed uint256,indexed
            address,uint256,uint256,uint256,uint256,string)
          handler: handleBetPlaced
        - event: BetClaimed(indexed uint256,indexed address,uint256)
          handler: handleBetClaimed
        - event: FeeCollected(uint256)
          handler: handleFeeCollected
        - event: AggregationCompleted(indexed uint256,uint256)
          handler: handleAggregationCompleted
        - event: BucketPriceSet(indexed uint256,uint256)
          handler: handleBucketPriceSet
        - event: BatchProcessed(indexed uint256,uint256,uint256)
          handler: handleBatchProcessed
        - event: SharesSold(indexed uint256,indexed address,uint256,uint256)
          handler: handleSharesSold

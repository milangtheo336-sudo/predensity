# Market Maker Bot v2 Configuration
# Copy this to your main .env.local and configure

# ============================================================================
# REQUIRED
# ============================================================================

# Bot user ID (get from Clerk dashboard)
MM_USER_ID=user_xxxxxxxxxxxxx

# Convex URL (should already be in .env.local)
NEXT_PUBLIC_CONVEX_URL=https://dynamic-anaconda-79.convex.cloud

# App URL (should already be in .env.local)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# MARKET SELECTION
# ============================================================================

# Specific markets to trade (comma-separated, leave empty for all)
MM_MARKET_IDS=

# Filter by categories (comma-separated, leave empty for all)
MM_CATEGORIES=sports,politics,technology

# ============================================================================
# QUOTING PARAMETERS
# ============================================================================

# Default order size in shares
MM_DEFAULT_SIZE=20

# Minimum spread in basis points (50 = 0.5%, 100 = 1%)
# Polymarket uses 10 bps (0.1%), but start wider for new markets
MM_MIN_SPREAD_BPS=50

# Price improvement step in basis points
MM_QUOTE_STEP_BPS=5

# Oversize threshold multiplier
MM_OVERSIZE_THRESHOLD=1.5

# ============================================================================
# INVENTORY MANAGEMENT
# ============================================================================

# Maximum net exposure in USD (positive)
MM_MAX_EXPOSURE_USD=5000

# Minimum net exposure in USD (negative)
MM_MIN_EXPOSURE_USD=-5000

# Target inventory balance (0 = neutral, positive = long bias, negative = short bias)
MM_TARGET_BALANCE=0

# Maximum inventory skew (0-1, where 0.3 = 30%)
# Bot stops quoting when skew exceeds this
MM_SKEW_LIMIT=0.3

# ============================================================================
# RISK MANAGEMENT
# ============================================================================

# Maximum USD per single order
MM_MAX_POSITION_SIZE_USD=2000

# Maximum shares per outcome
MM_MAX_POSITION_PER_OUTCOME=500

# Stop loss percentage (10 = 10%)
MM_STOP_LOSS_PCT=10

# ============================================================================
# TIMING
# ============================================================================

# Cancel/replace cycle interval in milliseconds
# Polymarket uses 500ms, we use 2000ms (2 seconds) for stability
MM_CANCEL_REPLACE_INTERVAL_MS=2000

# Order lifetime before cancellation (milliseconds)
MM_ORDER_LIFETIME_MS=10000

# Quote refresh rate (milliseconds)
MM_QUOTE_REFRESH_MS=1000

# Taker delay (milliseconds)
MM_TAKER_DELAY_MS=500

# ============================================================================
# BATCH OPERATIONS
# ============================================================================

# Enable batch cancellations (true/false)
MM_BATCH_CANCELLATIONS=true

# ============================================================================
# AUTO-REDEEM SERVICE
# ============================================================================

# Enable auto-redeem (true/false)
MM_AUTO_REDEEM=true

# Check interval for resolved markets (milliseconds)
MM_REDEEM_INTERVAL_MS=300000

# Minimum value to redeem (USD)
MM_REDEEM_THRESHOLD_USD=1

# ============================================================================
# MONITORING
# ============================================================================

# Log level (DEBUG, INFO, WARN, ERROR)
MM_LOG_LEVEL=INFO

# Enable Prometheus metrics endpoint (true/false)
MM_METRICS_ENABLED=false

# Metrics server port
MM_METRICS_PORT=9305

# ============================================================================
# RECOMMENDED CONFIGURATIONS
# ============================================================================

# CONSERVATIVE (Low Risk, Lower Returns)
# MM_MAX_EXPOSURE_USD=2000
# MM_SKEW_LIMIT=0.2
# MM_MIN_SPREAD_BPS=100
# MM_DEFAULT_SIZE=10

# BALANCED (Default)
# MM_MAX_EXPOSURE_USD=5000
# MM_SKEW_LIMIT=0.3
# MM_MIN_SPREAD_BPS=50
# MM_DEFAULT_SIZE=20

# AGGRESSIVE (High Risk, Higher Returns)
# MM_MAX_EXPOSURE_USD=10000
# MM_SKEW_LIMIT=0.4
# MM_MIN_SPREAD_BPS=30
# MM_DEFAULT_SIZE=50
